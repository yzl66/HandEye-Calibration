    // 法奥/通用 ZYX 欧拉角转矩阵 (保持不变)
    private static SimpleMatrix poseToMatrix(double x, double y, double z, double rx_deg, double ry_deg, double rz_deg) {
        double rx = Math.toRadians(rx_deg);
        double ry = Math.toRadians(ry_deg);
        double rz = Math.toRadians(rz_deg);
        double cx = Math.cos(rx), sx = Math.sin(rx);
        double cy = Math.cos(ry), sy = Math.sin(ry);
        double cz = Math.cos(rz), sz = Math.sin(rz);
        // 注意：这里假设是标准的旋转矩阵构造，Rx*Ry*Rz 或 Rz*Ry*Rx，具体取决于你的机器人控制器定义
        // 此处沿用你原代码的逻辑
        SimpleMatrix Rx = new SimpleMatrix(3, 3, true, new double[]{1, 0, 0, 0, cx, -sx, 0, sx, cx});
        SimpleMatrix Ry = new SimpleMatrix(3, 3, true, new double[]{cy, 0, sy, 0, 1, 0, -sy, 0, cy});
        SimpleMatrix Rz = new SimpleMatrix(3, 3, true, new double[]{cz, -sz, 0, sz, cz, 0, 0, 0, 1});
        SimpleMatrix R = Rz.mult(Ry).mult(Rx); // 这里的顺序非常重要，通常是 ZYX 或 XYZ
        SimpleMatrix T = SimpleMatrix.identity(4);
        T.insertIntoThis(0, 0, R);
        T.set(0, 3, x);
        T.set(1, 3, y);
        T.set(2, 3, z);
        return T;
    }

    // 【修改】不再盲目搜索，而是使用 Initial Guess
    private static void runGuidedCalibration(double[][] pc_raw, List<SimpleMatrix> flangePoses, SimpleMatrix initialGuess) {
        // 将原始点转为矩阵列表
        List<SimpleMatrix> camPoints = new ArrayList<>();
        for (double[] p : pc_raw) {
            // 直接使用原始数据，因为初始猜测矩阵会处理旋转关系
            camPoints.add(new SimpleMatrix(3, 1, true, new double[]{p[0], p[1], p[2]}));
        }

        // 运行带初值的迭代标定
        CalibrationResult res = runIterativeCalibration(camPoints, flangePoses, initialGuess);

        System.out.println("\n=== 最终结果 ===");
        System.out.printf("残差误差: %.3f mm\n", res.error);

        SimpleMatrix cameraToFlange = SimpleMatrix.identity(4);
        cameraToFlange.insertIntoThis(0, 0, res.R);
        cameraToFlange.set(0, 3, res.t.get(0));
        cameraToFlange.set(1, 3, res.t.get(1));
        cameraToFlange.set(2, 3, res.t.get(2));

        System.out.println("\n=== 相机 -> 法兰 变换矩阵 (Camera in Flange Frame) ===");
        System.out.println(cameraToFlange);

        // 解析结果以便阅读
        double x = res.t.get(0);
        double y = res.t.get(1);
        double z = res.t.get(2);
        System.out.printf("平移 (XYZ): %.2f, %.2f, %.2f\n", x, y, z);
        // 这里省略了旋转矩阵转欧拉角的代码，直接看矩阵即可

        if (res.error < 10.0) {
            System.out.println(">>> 标定成功。");
        } else {
            System.out.println(">>> 误差较大。可能原因：1.初始猜测偏差太大 2.数据点太少(建议至少6-9组) 3.数据采集时旋转幅度不够大");
        }
    }

    static class CalibrationResult {
        SimpleMatrix R, t;
        double error;

        CalibrationResult(SimpleMatrix R, SimpleMatrix t, double error) {
            this.R = R;
            this.t = t;
            this.error = error;
        }
    }

    // 迭代核心算法
    private static CalibrationResult runIterativeCalibration(List<SimpleMatrix> camPoints, List<SimpleMatrix> flangePoses, SimpleMatrix initialGuess) {
        // 检查数据量
        if (flangePoses.size() < 10) {
            System.err.println("警告: 数据点过少 (" + flangePoses.size() + "组)。建议至少提供10-15组包含不同旋转姿态的数据，否则结果不可靠！");
        }

        // 1. 从初始猜测中提取 R 和 t
        SimpleMatrix R_est = initialGuess.extractMatrix(0, 3, 0, 3);
        SimpleMatrix t_est = initialGuess.extractMatrix(0, 3, 3, 4);

        // ==========================================================================
        // 【修复点 1】正确初始化 Target
        // 不能假设目标点在法兰原点，必须用 InitialGuess + 第一组相机数据推算世界坐标系下的目标点
        // 公式：P_world = T_flange_0 * T_guess * P_cam_0
        // ==========================================================================
        SimpleMatrix p_cam_0 = camPoints.get(0); // 3x1
        // 将 P_cam_0 转为 4x1
        SimpleMatrix p_cam_0_homo = new SimpleMatrix(4, 1);
        p_cam_0_homo.set(0, 0, p_cam_0.get(0));
        p_cam_0_homo.set(1, 0, p_cam_0.get(1));
        p_cam_0_homo.set(2, 0, p_cam_0.get(2));
        p_cam_0_homo.set(3, 0, 1.0);

        // 计算 P_flange_0 (使用初始猜测矩阵)
        SimpleMatrix p_flange_0 = initialGuess.mult(p_cam_0_homo); // 4x1

        // 计算 P_base (使用第一组机器人的法兰位姿)
        SimpleMatrix currentTarget = flangePoses.get(0).mult(p_flange_0); // 4x1

        // 只要前3维作为初始中心点
        currentTarget = currentTarget.extractMatrix(0, 4, 0, 1);

        System.out.println("初始推算的固定点世界坐标 (Initial World Point Guess):");
        System.out.printf("X: %.2f, Y: %.2f, Z: %.2f\n", currentTarget.get(0), currentTarget.get(1), currentTarget.get(2));
        // ==========================================================================

        double lastErr = Double.MAX_VALUE;

        // 迭代优化
        for (int iter = 0; iter < 100; iter++) {
            List<SimpleMatrix> targetsInFlangeFrame = new ArrayList<>();

            // 步骤 A: 假设 currentTarget 是真实的世界固定点，将其转换回每一组的法兰坐标系下
            // P_flange_expected = inv(T_base_to_flange) * P_world_fixed
            for (SimpleMatrix T_base_to_flange : flangePoses) {
                SimpleMatrix T_flange_to_base = T_base_to_flange.invert(); // 求逆较慢，生产环境可优化
                SimpleMatrix p_target_in_flange = T_flange_to_base.mult(currentTarget);
                targetsInFlangeFrame.add(p_target_in_flange.extractMatrix(0, 3, 0, 1));
            }

            // 步骤 B: 使用 Kabsch 算法计算 {Camera Points} -> {Flange Targets} 的最佳变换
            // 这会给出一个新的 T_cam_to_flange (即 R_est, t_est)
            SimpleMatrix[] pose = kabsch(camPoints, targetsInFlangeFrame);
            R_est = pose[0];
            t_est = pose[1];

            // 步骤 C: 使用新的 R_est, t_est 重新推算所有的世界坐标点，并求平均中心作为新的 currentTarget
            SimpleMatrix newCenter = new SimpleMatrix(4, 1);
            double totalDist = 0;

            // 构建当前的 T_cam_to_flange 4x4 矩阵
            SimpleMatrix T_new = SimpleMatrix.identity(4);
            T_new.insertIntoThis(0, 0, R_est);
            T_new.set(0, 3, t_est.get(0));
            T_new.set(1, 3, t_est.get(1));
            T_new.set(2, 3, t_est.get(2));

            for (int i = 0; i < camPoints.size(); i++) {
                // P_cam -> P_flange
                SimpleMatrix p_c = camPoints.get(i);
                SimpleMatrix p_c_4 = new SimpleMatrix(4, 1, true, new double[]{p_c.get(0), p_c.get(1), p_c.get(2), 1.0});
                SimpleMatrix p_f = T_new.mult(p_c_4);

                // P_flange -> P_base
                SimpleMatrix p_b = flangePoses.get(i).mult(p_f);

                newCenter = newCenter.plus(p_b);

                // 累加残差 (点到中心的距离)
                double dist = Math.sqrt(Math.pow(p_b.get(0) - currentTarget.get(0), 2) +
                        Math.pow(p_b.get(1) - currentTarget.get(1), 2) +
                        Math.pow(p_b.get(2) - currentTarget.get(2), 2));
                totalDist += dist;
            }

            // 更新中心点
            newCenter = newCenter.divide(camPoints.size());
            // 保持齐次坐标最后一位是1
            newCenter.set(3, 1.0);

            double avgErr = totalDist / camPoints.size();

            // 打印收敛过程
            if (iter % 10 == 0 || iter == 0) {
                // System.out.printf("Iter %d, Mean Error: %.4f mm\n", iter, avgErr);
            }

            if (Math.abs(lastErr - avgErr) < 0.00001) break; // 收敛阈值
            lastErr = avgErr;
            currentTarget = newCenter;
        }
        // ================= 排查毒瘤数据 =================
        System.out.println("\n=== 各组数据残差排查 (揪出毒瘤) ===");

        // 用最终算出的旋转和平移重构变换矩阵
        SimpleMatrix final_T = SimpleMatrix.identity(4);
        final_T.insertIntoThis(0, 0, R_est);
        final_T.set(0, 3, t_est.get(0));
        final_T.set(1, 3, t_est.get(1));
        final_T.set(2, 3, t_est.get(2));

        for (int i = 0; i < camPoints.size(); i++) {
            SimpleMatrix p_c = camPoints.get(i);
            SimpleMatrix p_c_4 = new SimpleMatrix(4, 1, true, new double[]{p_c.get(0), p_c.get(1), p_c.get(2), 1.0});
            // 这里使用 final_T
            SimpleMatrix p_f = final_T.mult(p_c_4);
            SimpleMatrix p_b = flangePoses.get(i).mult(p_f);

            // 计算这个点到最终中心的偏差距离
            double dist = Math.sqrt(Math.pow(p_b.get(0) - currentTarget.get(0), 2) +
                    Math.pow(p_b.get(1) - currentTarget.get(1), 2) +
                    Math.pow(p_b.get(2) - currentTarget.get(2), 2));
            System.out.printf("第 %d 组数据: 自身误差 = %5.2f mm\n", i, dist);
        }
        // ===============================================

        return new CalibrationResult(R_est, t_est, lastErr);
    }


    private static SimpleMatrix[] kabsch(List<SimpleMatrix> src, List<SimpleMatrix> tgt) {
        int n = src.size();
        SimpleMatrix cS = new SimpleMatrix(3, 1), cT = new SimpleMatrix(3, 1);
        for (int i = 0; i < n; i++) {
            cS = cS.plus(src.get(i));
            cT = cT.plus(tgt.get(i));
        }
        cS = cS.divide(n);
        cT = cT.divide(n);
        SimpleMatrix H = new SimpleMatrix(3, 3);
        for (int i = 0; i < n; i++)
            H = H.plus(src.get(i).minus(cS).mult(tgt.get(i).minus(cT).transpose()));
        SimpleSVD<SimpleMatrix> svd = H.svd();
        SimpleMatrix R = svd.getV().mult(svd.getU().transpose());
        if (R.determinant() < 0) {
            SimpleMatrix V = svd.getV().copy();
            V.set(0, 2, -V.get(0, 2));
            V.set(1, 2, -V.get(1, 2));
            V.set(2, 2, -V.get(2, 2));
            R = V.mult(svd.getU().transpose());
        }
        return new SimpleMatrix[]{R, cT.minus(R.mult(cS))};
    }
